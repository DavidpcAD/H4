# Copiar como .env.local y rellenar SQL_USER / SQL_PASSWORD.
# En Azure App Service estas mismas keys van en Configuration → Application settings.

# Auth (JWT en cookie httpOnly)
JWT_SECRET="cambia-esto-por-un-secreto-largo-de-32+chars"
JWT_EXPIRES_IN="8h"

# Azure SQL (AdelanteSBX)
SQL_SERVER="mysqladelante.database.windows.net"
SQL_PORT="1433"
SQL_DATABASE="AdelanteSBX"
SQL_USER=""
SQL_PASSWORD=""

# Opcional: override del nombre de tabla (default dbo.Usuario)
# SQL_TABLE_USUARIO="dbo.Usuario"
